{
    "name": "repo-base",
    "dockerComposeFile": [
        "devc.docker-compose.yaml"
    ],
    "service": "dev",
    "workspaceFolder": "/workspace",
    "shutdownAction": "stopCompose",
    "remoteEnv": {
        "PROJECT_ID": "${localEnv:PROJECT_ID}"
    },
    "initializeCommand": "bash -c '[ -f .tooling.env ] || make setup.project; ln -sf ../.tooling.env .devcontainer/.env'",
    "overrideCommand": false,
    "runServices": [
        "dev"
    ],
    "customizations": {
        "vscode": {
            "extensions": []
        }
    }
}